---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Market Maker',
  description = 'eBay arbitrage tool that finds underpriced listings using AI-powered market analysis.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content="Market Maker — Find Underpriced eBay Listings" />
    <meta property="og:description" content="AI-powered eBay arbitrage tool that finds profit opportunities using variant-level price matching." />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-[#1e1e1e] text-[#e0e0e0] font-['Inter',sans-serif] antialiased">
    <slot />
  </body>
</html>
