<section id="waitlist" class="py-28 px-6 relative">
  <!-- Subtle divider gradient -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#22c55e]/20 to-transparent"></div>

  <!-- Ambient glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[radial-gradient(ellipse,rgba(34,197,94,0.06),transparent_70%)] pointer-events-none"></div>

  <div class="fade-up max-w-xl mx-auto text-center relative">
    <span class="tag-green tag mb-6 inline-block">Early Access</span>
    <h2 class="font-['Outfit',sans-serif] text-4xl md:text-5xl font-700 text-white tracking-tight">
      Get Your Edge
    </h2>
    <p class="mt-5 text-[#8b8d95] text-lg leading-relaxed">
      Be the first to know when Market Maker launches. Join the waitlist and get early access.
    </p>
    <form name="waitlist" method="POST" data-netlify="true" class="mt-10 flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input type="hidden" name="form-name" value="waitlist" />
      <input
        type="email"
        name="email"
        required
        placeholder="you@example.com"
        class="flex-1 px-5 py-3.5 rounded-xl bg-white/[0.04] border border-white/[0.08] text-white placeholder-[#555] focus:outline-none focus:border-[#38bdf8]/50 focus:bg-white/[0.06] transition-all duration-300 font-['DM_Sans',sans-serif]"
      />
      <button
        type="submit"
        class="group relative px-7 py-3.5 rounded-xl font-semibold text-white overflow-hidden transition-all duration-300 hover:shadow-[0_0_25px_rgba(34,197,94,0.25)] hover:-translate-y-0.5 whitespace-nowrap"
      >
        <span class="absolute inset-0 bg-gradient-to-r from-[#16a34a] to-[#22c55e] opacity-90 group-hover:opacity-100 transition-opacity"></span>
        <span class="relative flex items-center gap-2">
          Join Waitlist
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </button>
    </form>
    <p class="mt-5 text-xs text-[#555] font-['JetBrains_Mono',monospace]">No spam. Unsubscribe anytime.</p>
  </div>
</section>
