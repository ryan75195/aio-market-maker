<section class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-white text-center mb-16">How It Works</h2>

    <div class="grid md:grid-cols-3 gap-8 relative">

      <!-- Connector lines (desktop only) -->
      <div class="hidden md:block absolute top-6 left-1/3 right-1/3 h-px border-t-2 border-dashed border-[#3c3c3c]"></div>

      <!-- Step 1 -->
      <div class="flex flex-col items-center text-center">
        <div class="w-12 h-12 rounded-full bg-[#0e639c] flex items-center justify-center text-white text-xl font-bold relative z-10">
          1
        </div>
        <h3 class="text-xl font-semibold text-white mt-4">Set Up Your Jobs</h3>
        <p class="text-[#a0a0a0] mt-2 leading-relaxed">
          Tell Market Maker what products you flip. Create search jobs like "PS5 console" or "AirPods Pro" and organize them into categories.
        </p>
      </div>

      <!-- Step 2 -->
      <div class="flex flex-col items-center text-center">
        <div class="w-12 h-12 rounded-full bg-[#0e639c] flex items-center justify-center text-white text-xl font-bold relative z-10">
          2
        </div>
        <h3 class="text-xl font-semibold text-white mt-4">Scan the Market</h3>
        <p class="text-[#a0a0a0] mt-2 leading-relaxed">
          Hit Start Scrape. Market Maker finds active and sold listings on eBay, then uses ML to match each listing to its true variant-level comparables.
        </p>
      </div>

      <!-- Step 3 -->
      <div class="flex flex-col items-center text-center">
        <div class="w-12 h-12 rounded-full bg-[#0e639c] flex items-center justify-center text-white text-xl font-bold relative z-10">
          3
        </div>
        <h3 class="text-xl font-semibold text-white mt-4">Find Your Edge</h3>
        <p class="text-[#a0a0a0] mt-2 leading-relaxed">
          Browse opportunities sorted by profit. See exactly what comparable items sold for, how many comps support the price, and estimated days to sell.
        </p>
      </div>

    </div>
  </div>
</section>
